DATABASE_URL=postgresql://vending:vending123@localhost/vending_db

JETQR_BASE_URL=https://jetqr.aliftech.net
JETQR_API_KEY=
JETQR_MERCHANT_ID=
JETQR_STORE_ID=
JETQR_TERMINAL_ID=
JETQR_MIS_TERMINAL_ID=MIS-VND-001
# Точный merchant-facing endpoint возврата уточнить у JetQR/Aliftech:
JETQR_CANCEL_PATH=/api/v1/merchant/invoice/cancel

# Стартовый admin-аккаунт — создаётся один раз при первом запуске (пустая
# таблица пользователей). Дальше пользователей заводит сам admin через
# панель («Настройки» → «Пользователи»); эти значения после первого входа
# можно даже не менять в .env — они больше не используются.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me

# Папка для загруженных фото товаров (вне git-дерева, отдаётся по /uploads)
UPLOAD_DIR=/opt/vending-project/uploads
