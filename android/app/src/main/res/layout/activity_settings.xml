<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/brand_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"
            android:text="@string/settings_hint"
            android:textColor="#6B6B6B"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/inputMachineId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_machine_id"
            android:inputType="text"
            android:autofillHints="" />

        <EditText
            android:id="@+id/inputServerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/settings_server_url"
            android:inputType="textUri"
            android:autofillHints="" />

        <EditText
            android:id="@+id/inputToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/settings_token"
            android:inputType="textVisiblePassword"
            android:autofillHints="" />

        <EditText
            android:id="@+id/inputSerialPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/settings_serial_port"
            android:inputType="text"
            android:autofillHints="" />

        <CheckBox
            android:id="@+id/inputPortrait"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/settings_portrait"
            android:textColor="@color/brand_dark" />

        <CheckBox
            android:id="@+id/inputReverse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_reverse"
            android:textColor="@color/brand_dark" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/brand_accent"
            android:text="@string/settings_save"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>
