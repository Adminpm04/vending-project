<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_dark">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Показывается при потере связи с сервером / загрузке -->
    <LinearLayout
        android:id="@+id/statusOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/brand_dark"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/statusSpinner"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="@color/brand_accent" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:paddingHorizontal="40dp"
            android:text="@string/err_not_configured"
            android:textColor="@color/brand_light"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Невидимая зона в углу: долгое нажатие открывает настройки техника -->
    <View
        android:id="@+id/settingsHotspot"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="top|start" />

</FrameLayout>
